# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Domains (used by Caddy)
DOMAIN=boardgameclub.com
STAGING_DOMAIN=staging.boardgameclub.com

# Production database
DATABASE_URL=postgres://boardgameclub:changeme@db:5432/boardgameclub
DB_HOST=db
POSTGRES_DB=boardgameclub
POSTGRES_USER=boardgameclub
POSTGRES_PASSWORD=changeme

# Staging database
STAGING_POSTGRES_DB=boardgameclub_staging
STAGING_POSTGRES_USER=boardgameclub
STAGING_POSTGRES_PASSWORD=changeme

# Staging basic auth (generate hash with: docker run --rm caddy:2 caddy hash-password --plaintext 'your-password')
BASIC_AUTH_USER=tester
BASIC_AUTH_PASSWORD_HASH=

# Production hosts and security
ALLOWED_HOSTS=boardgameclub.com
SECURE_PROXY_SSL_HEADER=True
CSRF_TRUSTED_ORIGINS=https://boardgameclub.com

# Email
REQUIRE_EMAIL_VERIFICATION=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@localhost
